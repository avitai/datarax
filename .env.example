# Optional user-owned environment overrides loaded by activate.sh.
# The generated backend file is `.datarax.env`; setup.sh rewrites that file, not this one.
# Copy this file to `.env` when you want machine-local or developer-local overrides.

# Example: force CPU execution even when a GPU runtime is installed.
# export JAX_PLATFORMS="cpu"

# Example: override the generated backend label used by helper scripts.
# export DATARAX_BACKEND="cpu"

# Example: enable 64-bit mode for debugging or numerically sensitive experiments.
# export JAX_ENABLE_X64="1"

# Example: quiet TensorFlow/JAX C++ logging further on your local machine.
# export TF_CPP_MIN_LOG_LEVEL="2"
